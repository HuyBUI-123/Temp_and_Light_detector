DATABASE_URL=postgres://sensors:sensors@localhost:5432/sensors

# HTTP port the API listens on (the ESP32 and frontend expect 8000).
PORT=8000

# Light on/off threshold, in percent. is_on = light_percent >= threshold.
LIGHT_ON_THRESHOLD=50

# Data retention: readings older than this many hours are deleted.
RETENTION_HOURS=24

# How often the cleanup job runs, in minutes.
CLEANUP_INTERVAL_MINUTES=10
